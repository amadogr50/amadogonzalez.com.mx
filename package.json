{
  "name": "amadogonzalez.dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "dotenv -e .env turbo run @amado/web#dev",
    "cms:generate": "dotenv -e .env turbo run @amado/web#generate:importmap",
    "cms:migrate": "dotenv -e .env turbo run @amado/web#migrate",
    "cms:migrate:create": "dotenv -e .env turbo run @amado/web#migrate:create",
    "infra:up": "dotenv -e .env -- docker compose -f infra/docker/compose.yml up -d",
    "infra:down": "dotenv -e .env -- docker compose -f infra/docker/compose.yml down",
    "infra:reset": "dotenv -e .env -- docker compose -f infra/docker/compose.yml down -v",
    "infra:logs": "dotenv -e .env -- docker compose -f infra/docker/compose.yml logs -f",
    "infra:stop": "dotenv -e .env -- docker compose -f infra/docker/compose.yml stop",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@amado/prettier-config": "workspace:*",
    "@eslint/js": "^8.57.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-perfectionist": "^2.11.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-turbo": "^2.8.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^7.0.0"
  },
  "prettier": "@amado/prettier-config",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}
